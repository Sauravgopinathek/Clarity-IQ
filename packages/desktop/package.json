{
  "name": "@clarityiq/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js",
    "build": "tsc && node ../../node_modules/vite/bin/vite.js build && tsc -p electron && electron-builder",
    "electron:dev": "tsc -p tsconfig.node.json && node ../../scripts/dev-runner.mjs app-electron",
    "electron:start": "node ../../scripts/electron-launch.mjs desktop",
    "electron:start:web": "node ../../scripts/electron-launch.mjs web"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.clarityiq.app",
    "productName": "ClarityIQ",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
